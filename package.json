{
    "name": "secure-share",
    "version": "1.0.0",
    "description": "One-time secret sharing application with secure coding practices",
    "main": "backend/src/server.js",
    "scripts": {
        "start": "node scripts/killPort5000.js && node backend/src/server.js",
        "dev": "node scripts/killPort5000.js && nodemon --watch backend/src backend/src/server.js",
        "dev:frontend": "npm start --prefix frontend",
        "dev:full": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
        "test": "jest --runInBand"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.0",
        "morgan": "^1.10.0",
        "uuid": "^9.0.1",
        "xss-clean": "^0.1.4"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "supertest": "^6.3.3"
    }
}
